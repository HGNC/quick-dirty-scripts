# Copy this file to .env and replace placeholder values.
#
# Required DB connection settings for CLI + DB-backed tests:
# - Database: MySQL
# - Schema: vgnc_public
# - Access: read-only is sufficient/recommended
#
# Example:
#   cp .env.example .env
#   # then edit .env

DB_HOST=localhost
DB_PORT=3306
DB_NAME=vgnc_public
DB_USER=your_username
DB_PASSWORD=your_password

# Optional: set to 1 only when you intentionally run the live Ensembl smoke test.
# RUN_EXTERNAL_ENSEMBL=1
